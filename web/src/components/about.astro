---
import { Image } from "astro:assets";
import { about } from "../content/site";
import founderImage from "../assets/about/founder-illustration.jpeg";
---

<section id="about" class="bg-jasper-stone/5 py-28 md:py-40">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="grid items-center gap-12 md:grid-cols-[55%_1fr] md:gap-20">
      <div>
        <p class="reveal section-label">{about.label}</p>
        <h2
          class="reveal mt-5 font-heading text-[clamp(2rem,4vw,2.75rem)] leading-[1.12] font-medium tracking-[-0.02em] text-indigo-batik"
          style="--reveal-delay: 0.1s"
        >
          {about.heading}
        </h2>
        {about.paragraphs.map((p, i) => (
          <p
            class:list={[
              "reveal mt-5 leading-relaxed",
              i === 0 ? "text-indigo-batik text-lg" : "text-indigo-batik/90",
            ]}
            style={`--reveal-delay: ${0.15 + i * 0.05}s`}
          >
            {p}
          </p>
        ))}
        <div class="reveal mt-8" style="--reveal-delay: 0.3s">
          <p class="font-heading font-medium text-copper-pot">{about.founder.name}</p>
          <p class="text-sm text-indigo-batik/70">{about.founder.title}</p>
        </div>
      </div>
      <div class="reveal-scale" style="--reveal-delay: 0.1s">
        <div class="about-image-wrapper">
          <Image
            src={founderImage}
            alt={`${about.founder.name}, ${about.founder.title} at Patina Design`}
            class="w-full object-cover"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 45vw"
            loading="lazy"
            quality={80}
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-image-wrapper {
    position: relative;
    max-width: 85%;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  .about-image-wrapper::before {
    content: '';
    position: absolute;
    top: 20px;
    left: -20px;
    width: 100%;
    height: 100%;
    background: var(--color-pink-shadow);
    opacity: 0.35;
    border-radius: 1rem;
  }

  .about-image-wrapper img,
  .about-image-wrapper picture {
    position: relative;
    z-index: 1;
    border-radius: 1rem;
  }

  @media (max-width: 767px) {
    .about-image-wrapper::before {
      left: 0;
      top: 12px;
    }
  }
</style>
