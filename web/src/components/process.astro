---
import { process as processData } from "../content/site";
---

<section id="process" class="bg-jasper-stone/10 py-28 md:py-40">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="reveal">
      <p class="section-label">{processData.label}</p>
      <h2 class="mt-5 font-heading text-[clamp(2rem,4vw,2.75rem)] leading-[1.12] font-medium tracking-[-0.02em] text-indigo-batik">
        {processData.heading}
      </h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-indigo-batik/70">
        {processData.intro}
      </p>
    </div>
    <div class="mt-14 grid gap-6 md:grid-cols-4">
      {
        processData.steps.map((step, i) => (
          <div
            class="reveal rounded-2xl bg-white p-8 transition-shadow duration-300 hover:shadow-sm"
            style={`--reveal-delay: ${i * 0.1}s`}
          >
            <span class="font-heading text-4xl md:text-5xl font-light text-copper-pot/30">
              {step.number}
            </span>
            <h3 class="mt-4 font-heading text-lg font-medium text-indigo-batik">{step.name}</h3>
            <p class="mt-3 leading-relaxed text-indigo-batik/60">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
    <div class="reveal mt-16 text-center" style="--reveal-delay: 0.4s">
      <p class="font-heading text-[clamp(1.25rem,3vw,1.5rem)] font-medium text-jasper-stone">
        {processData.bridging}
      </p>
      <a
        href={processData.cta.href}
        class="mt-6 inline-flex items-center rounded-full border-2 border-copper-pot px-8 py-4 font-heading text-sm font-medium text-copper-pot transition-all duration-300 hover:bg-copper-pot hover:text-white"
      >
        {processData.cta.label}
      </a>
    </div>
  </div>
</section>
