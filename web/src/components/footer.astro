---
import { Image } from "astro:assets";
import { nav, siteConfig } from "../content/site";
import logoImage from "../assets/about/logo.jpeg";
---

<footer class="bg-indigo-batik py-16 md:py-20">
  <div
    class="mx-auto flex max-w-[1200px] flex-col items-center gap-8 px-6"
  >
    <a
      href="#home"
      class="block"
      aria-label="Patina Design, back to top"
    >
      <Image
        src={logoImage}
        alt=""
        class="h-12 w-auto brightness-0 invert"
        widths={[160]}
        sizes="160px"
        loading="lazy"
        quality={90}
      />
    </a>
    <nav aria-label="Footer navigation">
      <ul class="flex flex-wrap justify-center gap-6" role="list">
        {
          nav.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-heading text-xs uppercase tracking-[0.2em] text-white/70 transition-colors duration-200 hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <p class="text-sm text-white/70">London, United Kingdom</p>
    <div class="flex gap-5">
      <a
        href={siteConfig.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="p-3 text-white/70 transition-colors duration-200 hover:text-white"
        aria-label="Patina Design on Instagram"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>
      <a
        href={siteConfig.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="p-3 text-white/70 transition-colors duration-200 hover:text-white"
        aria-label="Aysel Selimbeyoglu on LinkedIn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect x="2" y="9" width="4" height="12"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </a>
    </div>
    <p class="text-xs tracking-[0.1em] text-white/60">{siteConfig.copyright}</p>
    <p class="text-xs text-white/50">
      Website created in partnership with <a
        href="https://asksamm.com"
        target="_blank"
        rel="noopener noreferrer"
        class="underline transition-colors duration-200 hover:text-white/70"
      >Ask Samm</a>
    </p>
  </div>
</footer>
