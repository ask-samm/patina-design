---
import { contact, siteConfig } from "../content/site";
import ContactForm from "./contact-form.tsx";
---

<section id="contact" class="bg-jasper-stone/6 py-28 md:py-40">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="grid gap-12 md:grid-cols-2 md:gap-20">
      <!-- Left: copy, vertically spread to match form height -->
      <div class="reveal flex flex-col">
        <div>
          <p class="section-label">{contact.label}</p>
          <h2 class="mt-5 font-heading text-[clamp(2rem,4vw,2.75rem)] leading-[1.12] font-medium tracking-[-0.02em] text-indigo-batik">
            {contact.heading}
            <br />
            <span class="text-copper-pot">{contact.subheading}</span>
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-indigo-batik/80">
            {contact.intro}
          </p>
          <p class="mt-2 text-sm text-indigo-batik/80">
            {contact.location}
          </p>
        </div>
        <div class="mt-auto space-y-4 pt-8">
          <a
            href={`mailto:${contact.email}`}
            class="block text-lg text-copper-pot transition-colors hover:underline"
          >
            {contact.email}
          </a>
          <div class="flex gap-4">
            <a
              href={siteConfig.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="p-3 text-indigo-batik transition-colors duration-200 hover:text-copper-pot"
              aria-label="Patina Design on Instagram"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
            <a
              href={siteConfig.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="p-3 text-indigo-batik transition-colors duration-200 hover:text-copper-pot"
              aria-label="Aysel Selimbeyoglu on LinkedIn"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="reveal" style="--reveal-delay: 0.1s">
        <ContactForm client:visible />
      </div>
    </div>
  </div>
</section>
