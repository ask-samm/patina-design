---
import { services } from "../content/site";
---

<section id="services" class="bg-pink-shadow/12 py-28 md:py-40">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="reveal">
      <p class="section-label">{services.label}</p>
      <h2 class="mt-5 font-heading text-[clamp(2rem,4vw,2.75rem)] leading-[1.12] font-medium tracking-[-0.02em] text-indigo-batik">
        {services.heading}
      </h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-indigo-batik/80">
        {services.intro}
      </p>
    </div>
    <!-- Row 1: 2 wide cards -->
    <div class="mt-14 grid gap-6 sm:grid-cols-2">
      {
        services.items.slice(0, 2).map((service, i) => (
          <div
            class="reveal rounded-2xl bg-white p-8 transition-shadow duration-300 hover:shadow-sm"
            style={`--reveal-delay: ${i * 0.08}s`}
          >
            <h3 class="font-heading text-base font-medium text-indigo-batik">{service.name}</h3>
            <p class="mt-3 leading-relaxed text-indigo-batik/80">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
    <!-- Row 2: 3 equal cards -->
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.items.slice(2).map((service, i) => (
          <div
            class="reveal rounded-2xl bg-white p-8 transition-shadow duration-300 hover:shadow-sm"
            style={`--reveal-delay: ${(i + 2) * 0.08}s`}
          >
            <h3 class="font-heading text-base font-medium text-indigo-batik">{service.name}</h3>
            <p class="mt-3 leading-relaxed text-indigo-batik/80">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
    <div class="reveal mt-16 text-center" style="--reveal-delay: 0.4s">
      <a
        href={services.cta.href}
        class="mt-6 inline-flex items-center gap-2 font-heading text-sm font-medium text-copper-pot transition-colors duration-200 hover:text-copper-pot/70"
      >
        {services.cta.label}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
      </a>
    </div>
  </div>
</section>
