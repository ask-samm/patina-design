---
import Base from "../layouts/base.astro";
import { Image } from "astro:assets";
import logoImage from "../assets/about/logo.jpeg";
---

<Base>
  <main class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <p class="font-heading text-xs font-medium uppercase tracking-[0.2em] text-copper-pot-text">
      404
    </p>
    <Image
      src={logoImage}
      alt="Patina Design"
      class="mt-6 h-16 w-auto mix-blend-multiply"
      widths={[140, 280]}
      sizes="140px"
      loading="eager"
    />
    <h1 class="mt-6 font-heading text-[clamp(2rem,4vw,2.75rem)] font-medium leading-tight tracking-[-0.02em] text-indigo-batik">
      Page not found
    </h1>
    <p class="mt-3 max-w-md text-lg leading-relaxed text-indigo-batik/70">
      Sorry, nothing to see here...
    </p>
    <a
      href="/"
      class="mt-8 font-heading text-sm font-medium uppercase tracking-[0.15em] text-copper-pot transition-colors duration-200 hover:text-copper-pot-text"
    >
      Back to homepage
    </a>
  </main>
</Base>
